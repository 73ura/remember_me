# ===========================================
# 開発環境用環境変数設定例
# ===========================================

# PostgreSQL設定
POSTGRES_DB=your_db
POSTGRES_USER=your_user_name
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=XXXX

# Rails設定
RAILS_ENV=your_setting
RAILS_PORT=XXXX

# データベースURL（自動生成されるが、必要に応じて上書き可能）
# DATABASE_URL=your_db_url

# 使用方法:
# 1. cp .env.example .env
# 2. .env を編集
# 3. docker-compose up
