# ===========================================
# 開発環境用環境変数設定例
# ===========================================

# PostgreSQL設定
POSTGRES_DB=remember_me_development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# Rails設定
RAILS_ENV=development
RAILS_PORT=3000

# データベースURL（自動生成されるが、必要に応じて上書き可能）
# DATABASE_URL=postgresql://postgres:password@db:5432/remember_me_development

# 使用方法:
# 1. cp .env.example .env
# 2. 必要に応じて .env を編集
# 3. docker-compose up
